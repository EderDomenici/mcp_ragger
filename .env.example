# Copie para .env e preencha sua chave real.
GOOGLE_API_KEY=

# Providers: google, llamacpp
EMBEDDING_PROVIDER=
GOOGLE_EMBEDDING_MODEL=
# GOOGLE_EMBEDDING_DIMENSIONS=768

QDRANT_URL=
# Necessario para Qdrant Cloud ou Qdrant remoto autenticado.
QDRANT_API_KEY=
QDRANT_COLLECTION=langchain_docs
DOCS_URL=

TOP_K=3
CANDIDATE_K=20
CHUNK_CAP=600
MIN_SCORE=0.60
MIN_QUERY_TERM_COVERAGE=0.75

# Usado apenas quando EMBEDDING_PROVIDER=llamacpp.
LLAMACPP_URL=http://localhost:8080/v1/embeddings

# Judge para avaliacoes Ragas via OpenRouter.
OPENROUTER_API_KEY=
RAGAS_JUDGE_PROVIDER=openrouter
RAGAS_JUDGE_MODELS=deepseek/deepseek-v4-flash,google/gemini-2.5-flash
RAGAS_JUDGE_TEMPERATURE=0
RAGAS_JUDGE_MAX_TOKENS=4096
OPENROUTER_APP_TITLE=langchain-rag-mcp
# Mantem o OpenRouter longe de providers que nao suportam json_object usado pelo Ragas.
OPENROUTER_REQUIRE_PARAMETERS=true
# DeepInfra nao suporta json_object para Nemotron; Ragas precisa de JSON estruturado.
OPENROUTER_PROVIDER_IGNORE=deepinfra
