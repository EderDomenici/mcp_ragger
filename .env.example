# Copie para .env e preencha sua chave real.
GOOGLE_API_KEY=

# Providers: google, llamacpp
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
# GOOGLE_EMBEDDING_DIMENSIONS=768

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=langchain_docs

# Usado apenas quando EMBEDDING_PROVIDER=llamacpp.
LLAMACPP_URL=http://localhost:8080/v1/embeddings
